# SQLite
DATA_DIR_PATH=../data
DB_PATH=../../../data/sortida/youtubers_programacio_test.sqlite


# Logging Configuration
LOG_LEVEL=debug                        # error, warn, info, http, verbose, debug, silly
LOG_FILE_PATH=../data/logs                  # Directori on es guardaran els logs
LOG_MAX_SIZE=20m                      # Mida màxima per fitxer
LOG_MAX_FILES=14d                     # Temps de retenció dels logs

# PR3.2 WebSocket game events
WS_PORT=8082
WS_HOST=127.0.0.1
INACTIVITY_TIMEOUT_MS=10000
MONGODB_URI=mongodb://root:password@localhost:27017/
MONGODB_DB_NAME=pr32_game_db
MONGODB_COLLECTION=movements